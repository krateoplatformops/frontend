{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "apiVersion": {
      "description": "kubernetes api version",
      "type": "string",
      "const": "widgets.templates.krateo.io/v1alpha1"
    },
    "Kind": {
      "type": "string",
      "const": "Drawer",
      "description": "name of the k8s Custom Resource"
    },
    "metadata": {
      "description": "kubernetes metadata",
      "type": "object",
      "properties": {
        "namespace": { "type": "string" },
        "name": { "type": "string" }
      },
      "required": ["namespace", "name"],
      "additionalProperties": false
    },
    "spec": {
      "type": "object",
      "required": ["content", "size", "title"],
      "properties": {
        "content": {
          "description": "the widgets to be displayed inside the drawer",
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "type": { "type": "string", "enum": ["Button"] },
              "props": {
                "type": "object",
                "additionalProperties": false
              }
            },
            "required": ["type", "props"],
            "additionalProperties": false
          }
        },
        "extra": {
          "description": "extra widgets to be displayed in the drawer header",
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "type": { "type": "string", "enum": ["Button"] },
              "props": {
                "type": "object",
                "additionalProperties": false
              }
            },
            "required": ["type", "props"],
            "additionalProperties": false
          }
        },
        "footer": {
          "description": "widgets to be displayed in the drawer footer",
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "type": { "type": "string", "enum": ["Button"] },
              "props": { "type": "object", "additionalProperties": false }
            },
            "required": ["type", "props"],
            "additionalProperties": false
          }
        },
        "size": {
          "description": "the size of the drawer",
          "type": "string",
          "enum": ["default", "large"]
        },
        "title": {
          "description": "the title of the drawer",
          "type": "string"
        },
        "width": {
          "description": "the width of the drawer in pixels",
          "type": "number"
        }
      },
      "additionalProperties": false
    }
  },
  "required": ["apiVersion", "Kind", "metadata", "spec"],
  "additionalProperties": false
}
