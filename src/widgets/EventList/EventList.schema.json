{
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "version": {
      "description": "widget version",
      "type": "string",
      "default": "v1beta1"
    },
    "kind": {
      "default": "EventList",
      "description": "EventList renders data coming from a Kubernetes cluster or Server Sent Events associated to a specific endpoint and topic",
      "type": "string"
    },
    "spec": {
      "type": "object",
      "properties": {
        "widgetData": {
          "type": "object",
          "required": ["events"],
          "properties": {
            "events": {
              "type": "array",
              "description": "list of events received from a k8s cluster or server sent event",
              "items": {
                "type": "object",
                "required": [
                  "global_uid",
                  "cluster_name",
                  "namespace",
                  "resource_kind",
                  "resource_name",
                  "event_type",
                  "reason",
                  "message",
                  "created_at",
                  "raw"
                ],
                "properties": {
                  "global_uid": {
                    "type": "string",
                    "description": "unique identifier of the event"
                  },
                  "cluster_name": {
                    "type": "string",
                    "description": "name of the cluster"
                  },
                  "namespace": {
                    "type": "string",
                    "description": "namespace the event belongs to"
                  },
                  "resource_kind": {
                    "type": "string",
                    "description": "resource type involved"
                  },
                  "resource_name": {
                    "type": "string",
                    "description": "unique name of the resource"
                  },
                  "event_type": {
                    "type": "string",
                    "enum": ["Normal", "Warning"],
                    "description": "type of the event, e.g., normal or warning"
                  },
                  "reason": {
                    "type": "string",
                    "description": "reason or cause of the event"
                  },
                  "message": {
                    "type": "string",
                    "description": "descriptive message of the event"
                  },
                  "created_at": {
                    "type": "string",
                    "format": "date-time",
                    "description": "creation date and time of the event"
                  },
                  "raw": {
                    "type": "string",
                    "description": "raw content of the event"
                  }
                },
                "additionalProperties": false
              },
              "tsType": "EventsApiResource[]"
            },
            "prefix": {
              "description": "filter prefix used to filter data",
              "type": "string"
            },
            "sseEndpoint": {
              "type": "string",
              "description": "endpoint url for server sent events connection"
            },
            "sseTopic": {
              "type": "string",
              "description": "subscription topic for server sent events"
            }
          },
          "additionalProperties": false
        },
        "resourcesRefs": {
          "type": "object",
          "properties": {
            "items": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "allowed": {
                    "type": "boolean"
                  },
                  "apiVersion": {
                    "type": "string"
                  },
                  "id": {
                    "type": "string"
                  },
                  "name": {
                    "type": "string"
                  },
                  "namespace": {
                    "type": "string"
                  },
                  "payload": {
                    "type": "object"
                  },
                  "resource": {
                    "type": "string"
                  },
                  "verb": {
                    "type": "string",
                    "enum": ["POST", "PUT", "PATCH", "DELETE", "GET"]
                  },
                  "slice": {
                    "type": "object",
                    "properties": {
                      "offset": {
                        "type": "integer"
                      },
                      "page": {
                        "type": "integer"
                      },
                      "perPage": {
                        "type": "integer"
                      },
                      "continue": {
                        "type": "boolean"
                      },
                      "cursor": {
                        "type": "string"
                      }
                    }
                  }
                },
                "required": ["id"]
              }
            }
          },
          "required": ["allowed", "id"]
        },
        "apiRef": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "namespace": {
              "type": "string"
            }
          },
          "required": ["name", "namespace"],
          "additionalProperties": false
        },
        "widgetDataTemplate": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "forPath": {
                "type": "string"
              },
              "expression": {
                "type": "string"
              }
            },
            "additionalProperties": false
          }
        }
      },
      "required": ["widgetData"],
      "additionalProperties": false
    }
  },
  "required": ["kind", "spec", "version"]
}
